// =========================================================================
// IronVault Core Operations Dashboard (dashboard.slint)
// =========================================================================

import { Theme } from "theme.slint";
import { Button, LineEdit } from "std-widgets.slint";

export component Dashboard inherits Rectangle {
    background: Theme.colors.background;

    // Callbacks out to controller
    callback verify-supervisor-keys(string, string);
    callback execute-downgrade-pump(string, string);
    callback trigger-logout();

    // Context & Binding State Display variables
    in-out property <string> selected-schema: "ironvault";
    in-out property <string> active-operator: "ADMINISTRATOR";
    in-out property <string> active-role: "superadmin";
    in-out property <string> crypto-signature-status: "❌ CHAIN UNSECURED // KEYS REQUIRED";
    in-out property <string> status-banner-text: "SYSTEM ONLINE // BINDING CONFIRMED";
    in-out property <color> status-banner-color: Theme.colors.success;

    VerticalLayout {
        // Upper Status Dashboard Banner
        Rectangle {
            height: 60px;
            background: Theme.colors.surface;
            border-bottom-width: 1px;
            border-color: Theme.colors.border;

            HorizontalLayout {
                padding-left: Theme.space-lg;
                padding-right: Theme.space-lg;
                alignment: space-between;

                Text {
                    text: root.status-banner-text;
                    color: root.status-banner-color;
                    font-size: 12px;
                    font-family: Theme.mono-font;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                
                HorizontalLayout {
                    spacing: Theme.space-md;
                    Text {
                        text: "OPERATOR: " + root.active-operator + " [" + root.active-role + "]";
                        color: Theme.colors.text-muted;
                        font-size: 12px;
                        font-family: Theme.mono-font;
                        vertical-alignment: center;
                    }
                    Button {
                        text: "🚪 LOGOUT";
                        clicked => {
                            root.trigger-logout();
                        }
                    }
                }
            }
        }

        // Inner Grid Layout containing controls & data lists
        VerticalLayout {
            padding: Theme.space-lg;
            spacing: Theme.space-lg;
            alignment: start;

            Text {
                text: "ironvault Workspace Control Core";
                color: Theme.colors.text;
                font-size: 22px;
                font-weight: 800;
            }

            // Interactive DB Operations Input Form
            Rectangle {
                background: Theme.colors.surface;
                border-width: 1px;
                border-color: Theme.colors.border;
                border-radius: Theme.border-radius;
                height: 120px;

                HorizontalLayout {
                    padding: Theme.space-md;
                    spacing: Theme.space-md;
                    alignment: space-between;

                    VerticalLayout {
                        width: 250px;
                        spacing: Theme.space-xs;
                        Text { text: "Schema Scope"; color: Theme.colors.text-muted; font-size: 10px; font-family: Theme.mono-font; }
                        schema-input := LineEdit { placeholder-text: "ironvault"; text: root.selected-schema; }
                    }

                    VerticalLayout {
                        width: 350px;
                        spacing: Theme.space-xs;
                        Text { text: "Replication Export Mapping Directory"; color: Theme.colors.text-muted; font-size: 10px; font-family: Theme.mono-font; }
                        dir-input := LineEdit { placeholder-text: "/var/backup/ironvault/dump"; }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: Theme.space-sm;

                        Button {
                            text: "📦 REPLICATE DB";
                            clicked => {
                                root.execute-downgrade-pump(schema-input.text, dir-input.text);
                            }
                        }
                    }
                }
            }

            // Cryptographic Handshake Gateway Control Panel Card
            Rectangle {
                background: Theme.colors.surface;
                border-width: 1px;
                border-color: Theme.colors.border;
                border-radius: Theme.border-radius;
                padding: Theme.space-md;
                height: 180px;

                VerticalLayout {
                    spacing: Theme.space-md;
                    Text {
                        text: "Supervisor Dual-Authorization Security Cryptographic Verification Gate";
                        color: Theme.colors.accent;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: Theme.space-md;
                        op-key := LineEdit { placeholder-text: "Primary Operator Private Verification Key..."; }
                        sv-key := LineEdit { placeholder-text: "Supervisor Certificate Authority Approval Key..."; }
                        Button {
                            text: "🔒 VERIFY KEYS";
                            clicked => {
                                root.verify-supervisor-keys(op-key.text, sv-key.text);
                            }
                        }
                    }

                    Text {
                        text: "AUTHORIZATION PIPELINE STATUS: " + root.crypto-signature-status;
                        color: Theme.colors.text-muted;
                        font-size: 11px;
                        font-family: Theme.mono-font;
                    }
                }
            }
        }
    }
}
