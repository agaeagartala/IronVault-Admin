// =========================================================================
// IronVault Core Operations Dashboard (dashboard.slint)
// =========================================================================

import { Theme } from "theme.slint";
import { Button, LineEdit } from "std-widgets.slint";

component DashboardRecordRow inherits Rectangle {
    in-out property <string> series: "";
    in-out property <string> acc-no: "";
    in-out property <string> sub-name: "";
    in-out property <string> status: "";

    background: Theme.colors.surface;
    height: 48px;

    Rectangle {
        y: parent.height - 1px;
        height: 1px;
        background: Theme.colors.border;
    }

    HorizontalLayout {
        padding-left: Theme.space-md;
        padding-right: Theme.space-md;
        alignment: space-between;

        Text { text: series; color: Theme.colors.text; font-size: 13px; vertical-alignment: center; width: 25%; }
        Text { text: acc-no; color: Theme.colors.text-muted; font-size: 13px; vertical-alignment: center; width: 25%; }
        Text { text: sub-name; color: Theme.colors.accent; font-size: 13px; vertical-alignment: center; width: 30%; }
        Text { text: status; color: Theme.colors.success; font-size: 13px; font-weight: 700; vertical-alignment: center; width: 20%; }
    }
}

export component Dashboard inherits Rectangle {
    background: Theme.colors.background;

    // Callbacks out to controller
    callback execute-crud-insert(string, string, string);
    callback execute-crud-update(string, string);
    callback execute-crud-delete(string);
    callback verify-supervisor-keys(string, string);

    // Context & Binding State Display variables
    in-out property <string> selected-schema: "ironvault";
    in-out property <string> active-operator: "ADMINISTRATOR";
    in-out property <string> crypto-signature-status: "❌ CHAIN UNSECURED // KEYS REQUIRED";
    in-out property <string> status-banner-text: "SYSTEM ONLINE // BINDING CONFIRMED";
    in-out property <color> status-banner-color: Theme.colors.success;

    // Local state fallbacks for the grid visualization
    in-out property <string> r1-id: "GPF-SERIES-01";
    in-out property <string> r1-account: "ACC-5524";
    in-out property <string> r1-name: "Primary Subscriber Record";

    VerticalLayout {
        // Upper Status Dashboard Banner
        Rectangle {
            height: 50px;
            background: Theme.colors.surface;
            border-bottom-width: 1px;
            border-color: Theme.colors.border;

            HorizontalLayout {
                padding-left: Theme.space-lg;
                padding-right: Theme.space-lg;
                alignment: space-between;

                Text {
                    text: root.status-banner-text;
                    color: root.status-banner-color;
                    font-size: 12px;
                    font-family: Theme.mono-font;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                Text {
                    text: "ACTIVE OPERATOR: " + root.active-operator;
                    color: Theme.colors.text-muted;
                    font-size: 12px;
                    font-family: Theme.mono-font;
                    vertical-alignment: center;
                }
            }
        }

        // Inner Grid Layout containing controls & data lists
        VerticalLayout {
            padding: Theme.space-lg;
            spacing: Theme.space-lg;
            alignment: start;

            Text {
                text: "ironvault.subscriber_details Workspace";
                color: Theme.colors.text;
                font-size: 22px;
                font-weight: 800;
            }

            // Interactive DB Operations Input Form
            Rectangle {
                background: Theme.colors.surface;
                border-width: 1px;
                border-color: Theme.colors.border;
                border-radius: Theme.border-radius;
                height: 120px;

                HorizontalLayout {
                    padding: Theme.space-md;
                    spacing: Theme.space-md;
                    alignment: space-between;

                    VerticalLayout {
                        width: 130px;
                        spacing: Theme.space-xs;
                        Text { text: "Series (Primary)"; color: Theme.colors.text-muted; font-size: 10px; font-family: Theme.mono-font; }
                        series-input := LineEdit { placeholder-text: "GPF-SERIES-01"; }
                    }

                    VerticalLayout {
                        width: 170px;
                        spacing: Theme.space-xs;
                        Text { text: "Account No (Primary Key)"; color: Theme.colors.text-muted; font-size: 10px; font-family: Theme.mono-font; }
                        acc-input := LineEdit { placeholder-text: "ACC-5524"; }
                    }

                    VerticalLayout {
                        width: 250px;
                        spacing: Theme.space-xs;
                        Text { text: "Subscriber Name"; color: Theme.colors.text-muted; font-size: 10px; font-family: Theme.mono-font; }
                        name-input := LineEdit { placeholder-text: "Operator full legal name..."; }
                    }

                    HorizontalLayout {
                        alignment: center;
                        spacing: Theme.space-sm;

                        Button {
                            text: "➕ INSERT";
                            clicked => {
                                root.execute-crud-insert(series-input.text, acc-input.text, name-input.text);
                                r1-id = series-input.text;
                                r1-account = acc-input.text;
                                r1-name = name-input.text;
                            }
                        }
                        Button {
                            text: "✏️ UPDATE";
                            clicked => {
                                root.execute-crud-update(acc-input.text, name-input.text);
                                r1-name = name-input.text;
                            }
                        }
                        Button {
                            text: "🗑️ DELETE";
                            clicked => {
                                root.execute-crud-delete(acc-input.text);
                                r1-id = "DELETED";
                                r1-account = "DELETED";
                                r1-name = "Record wiped from database catalog.";
                            }
                        }
                    }
                }
            }

            // Render Data List Grid
            VerticalLayout {
                Rectangle {
                    background: Theme.colors.surface-hover;
                    height: 40px;
                    border-radius: Theme.border-radius;
                    HorizontalLayout {
                        padding-left: Theme.space-md;
                        padding-right: Theme.space-md;
                        Text { text: "SERIES ID"; color: Theme.colors.text-muted; font-size: 11px; font-family: Theme.mono-font; vertical-alignment: center; width: 25%; }
                        Text { text: "ACCOUNT NO"; color: Theme.colors.text-muted; font-size: 11px; font-family: Theme.mono-font; vertical-alignment: center; width: 25%; }
                        Text { text: "SUBSCRIBER NAME"; color: Theme.colors.text-muted; font-size: 11px; font-family: Theme.mono-font; vertical-alignment: center; width: 30%; }
                        Text { text: "SECURITY ENVELOPE"; color: Theme.colors.text-muted; font-size: 11px; font-family: Theme.mono-font; vertical-alignment: center; width: 20%; }
                    }
                }

                DashboardRecordRow {
                    series: r1-id;
                    acc-no: r1-account;
                    sub-name: r1-name;
                    status: "ACTIVE (SSL)";
                }
            }

            // Cryptographic Handshake Gateway Control Panel Card
            Rectangle {
                background: Theme.colors.surface;
                border-width: 1px;
                border-color: Theme.colors.border;
                border-radius: Theme.border-radius;
                padding: Theme.space-md;
                height: 150px;

                VerticalLayout {
                    spacing: Theme.space-md;
                    Text {
                        text: "Supervisor Dual-Authorization Security Cryptographic Verification Gate";
                        color: Theme.colors.accent;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        spacing: Theme.space-md;
                        op-key := LineEdit { placeholder-text: "Primary Operator Private Verification Key..."; }
                        sv-key := LineEdit { placeholder-text: "Supervisor Certificate Authority Approval Key..."; }
                        Button {
                            text: "🔒 VERIFY KEYS";
                            clicked => {
                                root.verify-supervisor-keys(op-key.text, sv-key.text);
                            }
                        }
                    }

                    Text {
                        text: "AUTHORIZATION PIPELINE STATUS: " + root.crypto-signature-status;
                        color: Theme.colors.text-muted;
                        font-size: 11px;
                        font-family: Theme.mono-font;
                    }
                }
            }
        }
    }
}