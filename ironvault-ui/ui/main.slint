// =========================================================================
// IronVault Master Window Layout Coordinator (main.slint)
// =========================================================================

import { Theme } from "theme.slint";
import { LoginScreen } from "login.slint";
import { DashboardScreen } from "dashboard.slint";

export component AppWindow inherits Window {
    title: "IRONVAULT // Enterprise Administration Control Core";
    width: 1100px;
    height: 700px;
    background: Theme.colors.background;

    // Stateful global session flags tracked by controllers.rs
    in-out property <bool> is-authenticated: false;
    in-out property <string> current-user: "Unauthenticated Session";
    in-out property <string> current-role: "guest";
    in-out property <string> hardware-id: "FINGERPRINT-CALCULATING...";
    in-out property <string> error-message: "";

    // Global parameters matching ironvault system targets
    in-out property <string> selected-schema: "ironvault";
    in-out property <string> crypto-signature-status: "AWAITING AUTHORIZATION CHAIN";
    in-out property <string> status-banner-text: "SYSTEM INITIALIZED // SECURE CHANNEL ONLINE";
    in-out property <color> status-banner-color: Theme.colors.primary;

    // Interface functional interaction callbacks mapped out to controllers.rs
    callback attempt-login(string, string);
    callback trigger-registration(string, string);
    callback execute-crud-insert(string, string, string, string);
    callback execute-crud-update(string, string, string);
    callback execute-crud-delete(string, string);
    callback verify-supervisor-keys(string, string);
    callback execute-downgrade-pump(string, string);
    callback trigger-logout();

    // Structural Viewport Controller Layout
    if !is-authenticated : LoginScreen {
        error-message: root.error-message;
        hardware-id: root.hardware-id;
        
        attempt-login(user, pass) => {
            root.attempt-login(user, pass);
        }
        trigger-registration(user, pass) => {
            root.trigger-registration(user, pass);
        }
    }

    if is-authenticated : DashboardScreen {
        current-user: root.current-user;
        current-role: root.current-role;
        selected-schema: root.selected-schema;
        crypto-signature-status: root.crypto-signature-status;
        status-banner-text: root.status-banner-text;
        status-banner-color: root.status-banner-color;

        execute-crud-insert(schema, id, payload, status) => {
            root.execute-crud-insert(schema, id, payload, status);
        }
        execute-crud-update(schema, id, payload) => {
            root.execute-crud-update(schema, id, payload);
        }
        execute-crud-delete(schema, id) => {
            root.execute-crud-delete(schema, id);
        }
        verify-supervisor-keys(op-key, sv-key) => {
            root.verify-supervisor-keys(op-key, sv-key);
        }
        execute-downgrade-pump(schema, directory) => {
            root.execute-downgrade-pump(schema, directory);
        }
        trigger-logout() => {
            root.trigger-logout();
        }
    }
}