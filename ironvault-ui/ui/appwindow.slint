// =========================================================================
// IronVault Admin UI Declarative Layout (appwindow.slint)
// Designs the dark-themed administration console with sidebar navigation,
// high-contrast data tables, and secure dual-authorization panels.
// =========================================================================

import { Button, VerticalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "IronVault Admin - Secure Control Console";
    min-width: 1000px;
    min-height: 650px;
    background: #090a0f;

    // Application state links managed by our Rust engine
    in property <string> db-status-oracle19: "Active";
    in property <string> db-status-oracle11: "Active";
    in property <string> db-status-postgres: "Active";
    in property <string> crypto-signature-status: "Awaiting Input";
    
    callback execute-downgrade-pump(string, string);
    callback verify-supervisor-keys(string, string);

    HorizontalLayout {
        // 1. LEFT SIDEBAR NAVIGATION BAR
        Rectangle {
            width: 240px;
            background: #11131c;
            
            // Clean Native Vertical Border Edge (Simulates border-right-width)
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                height: parent.height;
                background: #1d212c;
            }

            VerticalLayout {
                padding: 20px;
                spacing: 15px;
                alignment: start;

                // Application Title Brand Header
                Text {
                    text: "IRONVAULT ADMIN";
                    font-size: 18px;
                    font-weight: 800;
                    color: #14b8a6;
                }
                
                // Active Section Tag Label
                Rectangle {
                    height: 1px;
                    background: #1d212c;
                }

                Text {
                    text: "🛡  Security Core Active";
                    font-size: 13px;
                    color: #a0aec0;
                }

                // Decorative separation spacer
                Rectangle { height: 20px; }

                // Sidebar Navigation Links
                Text { text: "📊  System Dashboard"; font-size: 14px; color: #ffffff; }
                Text { text: "🗄  Schema Operations"; font-size: 14px; color: #718096; }
                Text { text: "🔄  Data Pump Tools"; font-size: 14px; color: #718096; }
                Text { text: "🔑  Key Management"; font-size: 14px; color: #718096; }
            }
        }

        // 2. MAIN APPLICATION WORKSPACE AREA
        VerticalLayout {
            padding: 30px;
            spacing: 25px;
            alignment: start;

            // TOP SECTION: COMPLIANCE HEADER BLOCK
            Rectangle {
                height: 70px;
                background: #12141a;
                border-radius: 8px;
                border-width: 1px;
                border-color: #1d212c;

                HorizontalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    alignment: space-between;
                    
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Enterprise Node Management Console";
                            font-size: 20px;
                            font-weight: 700;
                            color: #ffffff;
                        }
                        Text {
                            text: "Local Node Air-Gapped Network Deployment Context";
                            font-size: 12px;
                            color: #718096;
                        }
                    }
                }
            }

            // MIDDLE SECTION: IN-HOUSE DATABASE NODE STATUSES
            HorizontalLayout {
                spacing: 20px;
                
                // ORACLE 19c STATUS TILE CONTAINER
                Rectangle {
                    background: #12141a;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #1d212c;
                    height: 110px;
                    
                    VerticalLayout {
                        padding: 15px;
                        spacing: 8px;
                        Text { text: "Oracle Database 19c Enterprise"; font-size: 14px; font-weight: 600; color: #a0aec0; }
                        Text { text: "Status: " + root.db-status-oracle19; font-size: 16px; font-weight: 700; color: #14b8a6; }
                        Text { text: "Network Transport Layer: Local Native Encryption (NNE)"; font-size: 11px; color: #718096; }
                    }
                }

                // ORACLE 11g LEGACY DOWNGRADE TARGET CONTAINER
                Rectangle {
                    background: #12141a;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #1d212c;
                    height: 110px;
                    
                    VerticalLayout {
                        padding: 15px;
                        spacing: 8px;
                        Text { text: "Oracle Database 11g Legacy"; font-size: 14px; font-weight: 600; color: #a0aec0; }
                        Text { text: "Status: " + root.db-status-oracle11; font-size: 16px; font-weight: 700; color: #e53e3e; }
                        Text { text: "Target Architecture Compatibility Context: 11.2.0"; font-size: 11px; color: #718096; }
                    }
                }

                // POSTGRESQL NODE TARGET CONTAINER
                Rectangle {
                    background: #12141a;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: #1d212c;
                    height: 110px;
                    
                    VerticalLayout {
                        padding: 15px;
                        spacing: 8px;
                        Text { text: "PostgreSQL Local Cluster"; font-size: 14px; font-weight: 600; color: #a0aec0; }
                        Text { text: "Status: " + root.db-status-postgres; font-size: 16px; font-weight: 700; color: #14b8a6; }
                        Text { text: "Certificate Pinning Validation Layer: Active"; font-size: 11px; color: #718096; }
                    }
                }
            }

            // BOTTOM SECTION: SECURE CONTROL FORM PANEL
            Rectangle {
                background: #12141a;
                border-radius: 8px;
                border-width: 1px;
                border-color: #1d212c;
                
                VerticalLayout {
                    padding: 25px;
                    spacing: 15px;

                    Text {
                        text: "Data Pump Version Control & Structural Transformation System";
                        font-size: 16px;
                        font-weight: 700;
                        color: #ffffff;
                    }

                    // Dual Signature Authority Approval Tracker
                    Rectangle {
                        background: #1a1d26;
                        border-radius: 4px;
                        height: 40px;
                        
                        HorizontalLayout {
                            padding-left: 15px;
                            padding-right: 15px;
                            alignment: space-between;
                            Text { text: "Dual Authorization Signature Chain Tracking Node Status:"; vertical-alignment: center; font-size: 13px; color: #a0aec0; }
                            Text { text: root.crypto-signature-status; vertical-alignment: center; font-size: 13px; font-weight: 700; color: #f6ad55; }
                        }
                    }

                    // TEXT FIELDS INPUT BLOCK
                    HorizontalLayout {
                        spacing: 15px;
                        
                        VerticalLayout {
                            spacing: 5px;
                            Text { text: "Oracle Database 19c System Source Schema Path Name:"; font-size: 12px; color: #a0aec0; }
                            source_input := LineEdit {
                                text: "SYSTEM.MIGRATION_SOURCE";
                                placeholder-text: "Enter Source Schema Node";
                            }
                        }

                        VerticalLayout {
                            spacing: 5px;
                            Text { text: "Oracle Data Pump Transform Backwards Directory Mapping Allocation:"; font-size: 12px; color: #a0aec0; }
                            dir_input := LineEdit {
                                text: "DATA_PUMP_DIR";
                                placeholder-text: "Enter Server Directory Context";
                            }
                        }
                    }

                    // CRITICAL CRYPTOGRAPHIC SIGNATURE PASSWORDS
                    HorizontalLayout {
                        spacing: 15px;
                        
                        VerticalLayout {
                            spacing: 5px;
                            Text { text: "Operator Execution Private Key Phrase Hex String Input:"; font-size: 12px; color: #a0aec0; }
                            op_key_input := LineEdit {
                                placeholder-text: "Hex String Operator Authorization Signature Identifier";
                            }
                        }

                        VerticalLayout {
                            spacing: 5px;
                            Text { text: "Supervisor Cryptographic Approver Signature Private Key Phrase:"; font-size: 12px; color: #a0aec0; }
                            sv_key_input := LineEdit {
                                placeholder-text: "Hex String Supervisor Dual-Authentication Approval Key";
                            }
                        }
                    }

                    // BOTTOM ACTION CONTROL SUBMIT BUTTONS
                    HorizontalLayout {
                        spacing: 20px;
                        alignment: end;

                        Button {
                            text: "🔒 Verify Cryptographic Authority Chain";
                            clicked => {
                                root.verify-supervisor-keys(op_key_input.text, sv_key_input.text);
                            }
                        }

                        Button {
                            text: "⚙ Execute Backward Compatibility Data Pump";
                            clicked => {
                                root.execute-downgrade-pump(source_input.text, dir_input.text);
                            }
                        }
                    }
                }
            }
        }
    }
}