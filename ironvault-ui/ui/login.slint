// =========================================================================
// IronVault Cyber-Vault Secure Login Canvas (login.slint)
// =========================================================================

import { Theme } from "theme.slint";
import { Button, LineEdit } from "std-widgets.slint";

export component LoginScreen inherits Rectangle {
    background: Theme.colors.background;
    
    in-out property <string> status-text: "";
    in-out property <color> status-color: Theme.colors.text-muted;
    in-out property <string> hardware-id: "CALCULATING PHYSICAL KEYWAY...";
    
    callback attempt-login(string, string);
    callback trigger-registration(string, string);

    VerticalLayout {
        padding-top: Theme.space-xl;
        padding-bottom: Theme.space-xl;
        spacing: Theme.space-lg;
        alignment: center;

        // Brand Typography Header
        VerticalLayout {
            spacing: Theme.space-xs;
            Text {
                text: "IRONVAULT // SYSTEM ADMIN";
                font-size: 26px;
                font-weight: 800;
                font-family: Theme.font-family;
                color: Theme.colors.accent;
                horizontal-alignment: center;
            }
            Text {
                text: "HARDWARE IDENTIFIER BINDING ENFORCED";
                font-size: 11px;
                font-family: Theme.mono-font;
                color: Theme.colors.text-muted;
                horizontal-alignment: center;
            }
        }

        // Lock Panel Card surface
        Rectangle {
            background: Theme.colors.surface;
            border-color: Theme.colors.border;
            border-width: 1px;
            border-radius: Theme.border-radius * 1.5;
            width: 440px;
            height: 340px;
            x: (parent.width - 440px) / 2;

            VerticalLayout {
                padding: Theme.space-lg * 1.2;
                spacing: Theme.space-md;

                Text {
                    text: "CRYPTOGRAPHIC CREDENTIAL ACCESS";
                    font-size: 13px;
                    font-family: Theme.mono-font;
                    color: Theme.colors.text;
                    font-weight: 700;
                    horizontal-alignment: center;
                }

                // Inputs
                VerticalLayout {
                    spacing: Theme.space-xs;
                    Text { text: "OPERATOR IDENTIFIER"; font-size: 10px; color: Theme.colors.text-muted; font-family: Theme.mono-font; }
                    username-input := LineEdit {
                        placeholder-text: "Enter operator identification key...";
                        height: 38px;
                    }
                }

                VerticalLayout {
                    spacing: Theme.space-xs;
                    Text { text: "SECRET VERIFICATION PASSWORD"; font-size: 10px; color: Theme.colors.text-muted; font-family: Theme.mono-font; }
                    password-input := LineEdit {
                        placeholder-text: "••••••••••••";
                        input-type: password;
                        height: 38px;
                    }
                }

                // Interactive Buttons
                HorizontalLayout {
                    spacing: Theme.space-md;
                    Button {
                        text: "SIGN IN";
                        primary: true;
                        height: 40px;
                        clicked => {
                            root.attempt-login(username-input.text, password-input.text);
                        }
                    }
                    Button {
                        text: "REGISTER ACCOUNT";
                        height: 40px;
                        clicked => {
                            root.trigger-registration(username-input.text, password-input.text);
                        }
                    }
                }
            }
        }

        // Live System status footer
        VerticalLayout {
            spacing: Theme.space-xs;
            Text {
                text: "LIVE FEEDBACK: " + root.status-text;
                color: root.status-color;
                font-size: 12px;
                font-family: Theme.mono-font;
                font-weight: 700;
                horizontal-alignment: center;
            }
            Text {
                text: "DEVICE BINDING FOOTPRINT: " + root.hardware-id;
                color: Theme.colors.text-muted;
                font-size: 10px;
                font-family: Theme.mono-font;
                horizontal-alignment: center;
            }
        }
    }
}