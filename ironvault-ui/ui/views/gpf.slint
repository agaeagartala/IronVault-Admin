import { Button, LineEdit, ScrollView } from "std-widgets.slint";
import { Theme } from "../theme.slint";

export struct GpfCaseDetails {
    regd_no: string,
    holder_name: string,
    series_id: string,
    account_no: string,
    balance: string,
    status: string
}

export component GpfFinalPaymentView inherits Rectangle {
    in-out property <string> active_schema_action;
    in-out property <string> op_status_msg;
    in-out property <bool> op_is_error;
   
    in-out property <string> op_regd_no;
    in-out property <string> op_series_id;
    in-out property <string> op_account_no;
    in-out property <string> op_gpf_new_status;
    in-out property <bool> gpf_case_found;
    in-out property <GpfCaseDetails> active_gpf_case;

    callback request_find_gpf_case(string);
    callback request_delete_full_case(string, string, string);
    callback request_delete_application(string);
    callback request_delete_precalc(string);
    callback request_delete_auth_reports(string);
    callback request_update_gpf_status(string, string);

    background: transparent;

    VerticalLayout {
        spacing: 20px;
        padding: 24px;

        // =========================================================================
        // MODERN ACCENT NAVIGATION
        // =========================================================================
        HorizontalLayout {
            spacing: 12px;
            alignment: start;

            Button {
                text: "🔍 Profile Acquisition Core";
                height: 42px;
                checked: root.active_schema_action == "gpffp_find";
                clicked => { root.active_schema_action = "gpffp_find"; }
            }

            Button {
                text: "🚨 Destructive Override Safehouse";
                height: 42px;
                checked: root.active_schema_action == "gpffp_clear";
                clicked => { root.active_schema_action = "gpffp_clear"; }
            }
        }

        // =========================================================================
        // FIND VIEW
        // =========================================================================
        if (root.active_schema_action == "gpffp_find") : Rectangle {
            background: @linear-gradient(145deg, #1e2937, #0f172a);
            border-radius: 20px;
            border-width: 1px;
            border-color: #6366f155;

            VerticalLayout {
                padding: 28px;
                spacing: 20px;

                Text {
                    text: "GPF RELATIONAL ENCLAVE INQUIRY";
                    font-size: 15px;
                    font-weight: 800;
                    letter-spacing: 1.5px;
                    color: #a5b4fc;
                }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;

                    VerticalLayout {
                        spacing: 6px;
                        width: 320px;

                        Text {
                            text: "REGISTRATION INDEX KEY";
                            font-size: 11px;
                            font-weight: 700;
                            color: #64748b;
                            letter-spacing: 0.8px;
                        }
                        LineEdit {
                            text <=> root.op_regd_no;
                            placeholder_text: "Ex: 45102/FP";
                            height: 48px;
                            font-size: 15px;
                        }
                    }

                    VerticalLayout {
                        alignment: end;
                        width: 160px;

                        Button {
                            text: "SCAN SECURE RING";
                            height: 48px;
                            clicked => { root.request_find_gpf_case(root.op_regd_no); }
                        }
                    }
                }

                // RESULT CARD
                if (root.gpf_case_found) : Rectangle {
                    background: #10b98110;
                    border-radius: 18px;
                    border-width: 1px;
                    border-color: #34d39966;

                    VerticalLayout {
                        padding: 24px;
                        spacing: 18px;

                        HorizontalLayout {
                            alignment: space-between;
                            VerticalLayout {
                                spacing: 4px;
                                Text {
                                    text: "ACTIVE LEDGER MATCH VERIFIED";
                                    font-size: 15px;
                                    font-weight: 800;
                                    color: #34d399;
                                }
                                Text {
                                    text: "Cryptographic session bound successfully";
                                    font-size: 12px;
                                    color: #a1a1aa;
                                }
                            }
                            Rectangle {
                                width: 12px;
                                height: 12px;
                                background: #34d399;
                            }
                        }

                        Rectangle { height: 1px; background: #334155; opacity: 0.6; }

                        HorizontalLayout {
                            spacing: 32px;
                            alignment: start;

                            VerticalLayout {
                                spacing: 4px;
                                width: 220px;
                                Text { text: "ACCOUNT HOLDER"; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 1px; }
                                Text { text: root.active_gpf_case.holder_name; font-size: 16px; font-weight: 700; color: #e0f2fe; }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                width: 110px;
                                Text { text: "SERIES"; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 1px; }
                                Text { text: root.active_gpf_case.series_id; font-size: 16px; font-family: "Consolas"; font-weight: 700; color: #fbbf24; }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                width: 150px;
                                Text { text: "ACCOUNT NO"; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 1px; }
                                Text { text: root.active_gpf_case.account_no; font-size: 16px; font-family: "Consolas"; color: #e0e7ff; }
                            }

                            VerticalLayout {
                                spacing: 4px;
                                width: 160px;
                                Text { text: "CLOSING BALANCE"; font-size: 10px; font-weight: 700; color: #64748b; letter-spacing: 1px; }
                                Text { text: "₹ " + root.active_gpf_case.balance; font-size: 18px; font-weight: 900; color: #67e8f9; }
                            }
                        }
                    }
                }
            }
        }

        // =========================================================================
        // DESTRUCTIVE VIEW
        // =========================================================================
        if (root.active_schema_action == "gpffp_clear") : Rectangle {
            background: @linear-gradient(90deg, #3f87a6 0%, #ebf8e1 100%); //  Fixed!
            border-radius: 20px;
            border-width: 1px;
            border-color: #f8717166;

            VerticalLayout {
                padding: 28px;
                spacing: 24px;

                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "CRITICAL ADMINISTRATIVE INTERFACE";
                        font-size: 15px;
                        font-weight: 800;
                        color: #fda4af;
                        letter-spacing: 1.2px;
                    }
                    Text {
                        text: "All actions are irreversible. Confirm targets before execution.";
                        font-size: 13px;
                        color: #fda4af88;
                    }
                }

                Rectangle { height: 1px; background: #f8717166; }

                HorizontalLayout {
                    spacing: 16px;
                    alignment: start;

                    VerticalLayout {
                        spacing: 6px;
                        width: 210px;
                        Text { text: "APPLICATION / REGD NO"; font-size: 11px; font-weight: 700; color: #94a3b8; }
                        LineEdit {
                            text <=> root.op_regd_no;
                            placeholder_text: "Ex: 45102/FP";
                            height: 46px;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        width: 150px;
                        Text { text: "SERIES PREFIX"; font-size: 11px; font-weight: 700; color: #94a3b8; }
                        LineEdit {
                            text <=> root.op_series_id;
                            placeholder_text: "Ex: EDN";
                            height: 46px;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        width: 210px;
                        Text { text: "ACCOUNT NO REFERENCE"; font-size: 11px; font-weight: 700; color: #94a3b8; }
                        LineEdit {
                            text <=> root.op_account_no;
                            placeholder_text: "Ex: 12435";
                            height: 46px;
                        }
                    }
                }

                Rectangle { height: 1px; background: #f8717166; }

                GridLayout {
                    spacing: 12px;
                    Row {
                        Button {
                            text: "💥 DROP FULL SETTLEMENT PROFILE";
                            height: 52px;
                            clicked => { root.request_delete_full_case(root.op_regd_no, root.op_series_id, root.op_account_no); }
                        }
                        Button {
                            text: "🗑️ PURGE APPLICATION ROW";
                            height: 52px;
                            clicked => { root.request_delete_application(root.op_regd_no); }
                        }
                    }
                    Row {
                        Button {
                            text: "📊 FLUSH PRE-CALCULATIONS";
                            height: 52px;
                            clicked => { root.request_delete_precalc(root.op_regd_no); }
                        }
                        Button {
                            text: "📜 DROP SIGNED CERTIFICATES";
                            height: 52px;
                            clicked => { root.request_delete_auth_reports(root.op_regd_no); }
                        }
                    }
                }
            }
        }
    }
}