import { Button, LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { RegisterView, RegisterFormFields } from "register.slint";

export { RegisterFormFields }

export component LoginView inherits Rectangle {
    in-out property <string> form_user: "";
    in-out property <string> form_pass: "";
    in-out property <string> login_error: "";
    in-out property <RegisterFormFields> registration_fields;
    property <string> screen_state: "landing";

    callback login_requested(string, string);
    callback registration_requested(string, string, string, string, string, string, string);

    horizontal-stretch: 1;
    background: Theme.bg-main;

    VerticalLayout {
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: root.screen_state == "register" ? 680px : 440px;
                background: Theme.bg-card;
                border-radius: 16px;
                border-width: 1px;
                border-color: Theme.border-color;
                drop-shadow-blur: 40px;
                drop-shadow-color: #00E5FF1A;
                animate width { duration: 200ms; easing: ease-in-out; }

                VerticalLayout {
                    padding: 40px;
                    spacing: 16px;

                    Text { text: "IRONVAULT"; font-size: 32px; font-weight: 900; color: Theme.brand-primary; horizontal-alignment: center; }
                    Rectangle { height: 1px; background: Theme.border-color; }

                    if (root.screen_state == "landing"): VerticalLayout {
                        spacing: 16px;
                        padding-top: 10px;
                        Button { text: "🔑  Access Terminal Login"; height: 45px; clicked => { root.screen_state = "login"; root.login_error = ""; } }
                        Button { text: "📝  Enroll New Node Profile"; height: 45px; clicked => { root.screen_state = "register"; root.login_error = ""; } }
                    }

                    if (root.screen_state == "login"): VerticalLayout {
                        spacing: 14px;
                        LineEdit { text <=> root.form_user; placeholder_text: "Operator ID"; height: 34px; }
                        LineEdit { text <=> root.form_pass; placeholder_text: "Secret Token"; input-type: password; height: 34px; }
                        Button { text: "Authenticate Access"; height: Theme.button-height; horizontal-stretch: 1; clicked => { root.login_requested(root.form_user, root.form_pass); } }
                        if (root.login_error != ""): Rectangle {
                            background: #FF336633; border-radius: 6px; border-width: 1px; border-color: Theme.brand-danger;
                            HorizontalLayout { padding: 8px; Text { text: root.login_error; color: #FFA0B4; font-size: 12px; font-weight: 600; horizontal-alignment: center; } }
                        }
                        HorizontalLayout {
                            spacing: 14px; padding-top: 18px;
                            Button { text: "Return Gateway"; height: Theme.button-height; horizontal-stretch: 1; clicked => { root.screen_state = "landing"; root.login_error = ""; } }
                        }
                    }

                    if (root.screen_state == "register"): RegisterView {
                        operational-error: root.login_error;
                        form-data <=> root.registration_fields;
                        submit-registration => {
                            root.registration_requested(
                                root.registration_fields.username, root.registration_fields.secret,
                                root.registration_fields.first-name, root.registration_fields.middle-name,
                                root.registration_fields.last-name, root.registration_fields.designation,
                                root.registration_fields.section
                            );
                        }
                        cancel-registration => { root.screen_state = "landing"; root.login_error = ""; }
                    }
                }
            }
        }
    }
}